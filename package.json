{
  "name": "mymd",
  "version": "1.4.3",
  "description": "Local-first Markdown desktop editor built with React, TypeScript, and Tauri.",
  "scripts": {
    "dev": "vite",
    "electron:dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && electron electron/main.cjs\"",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "build": "vite build",
    "build:electron": "npm run build && electron-builder --config electron-builder.json",
    "release:smoke": "node scripts/release-smoke-check.mjs",
    "iteration:audit": "node scripts/iteration-goal-audit.mjs",
    "wave0:gate": "node scripts/wave-gate-check.mjs --wave 0",
    "ci:repo-hygiene": "node scripts/repo-hygiene-check.mjs",
    "ci:check": "npm run ci:repo-hygiene && npm run build",
    "preview": "vite preview",
    "tauri": "tauri",
    "build:tauri": "tauri build"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language-data": "^6.5.2",
    "@milkdown/kit": "^7.18.0",
    "@milkdown/plugin-diagram": "^7.7.0",
    "@milkdown/plugin-math": "^7.5.9",
    "@milkdown/plugin-prism": "^7.18.0",
    "@prosemirror-adapter/react": "^0.2.6",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@uiw/react-codemirror": "^4.25.5",
    "codemirror": "^6.0.2",
    "katex": "^0.16.33",
    "lucide-react": "^0.474.0",
    "marked": "^17.0.5",
    "mdast-util-math": "^3.0.0",
    "mermaid": "^10.9.0",
    "p-queue": "^8.1.0",
    "postcss-import": "^16.1.1",
    "prism-themes": "^1.9.0",
    "prosemirror-search": "^1.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "refractor": "^5.0.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tauri-apps/cli": "^2.2.8",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.24",
    "concurrently": "^9.2.1",
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^6.0.0",
    "wait-on": "^8.0.5"
  }
}
